# Leave unset for DEMO mode (simulated live calls).
# Optional: real GPT replies in "Talk to Ava" (works without it via demo brain)
OPENAI_API_KEY=sk-YOUR-KEY

# Server-side (webhook ingestion → Supabase):
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY
RETELL_WEBHOOK_SECRET=YOUR-RETELL-SIGNING-SECRET
# Client-side (console reads live data):
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY
